# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_USER=tipster
POSTGRES_PASSWORD=tipster
POSTGRES_DB=tipster_db
DATABASE_URL=postgresql+asyncpg://tipster:tipster@db:5432/tipster_db

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Autenticação JWT ─────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── APIs externas ────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=sua-chave-aqui
OPENAI_API_KEY=sua-chave-aqui
# Alternativa: usar Claude (Anthropic)
ANTHROPIC_API_KEY=sua-chave-aqui

# ── Ambiente ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
